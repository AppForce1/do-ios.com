---
import Layout from "../layouts/Layout.astro";
import "../styles/theme-2026.css";
import Hero2026 from "../components/Hero2026.astro";
import HighlightCard2026 from "../components/HighlightCard2026.astro";
import CallForPapers from "../components/CallForPapers.astro";
import Hosts from "../components/Hosts2026.astro";
import Speakers from "../components/Speakers2026.astro";
import Support from "../components/Support2026.astro";
import Location from "../components/Location.astro";
import Tickets from "../components/Tickets.astro";
import Sponsors from "../components/Sponsors2026.astro";
import Agenda from "../components/Agenda2026.astro";
import Partners from "../components/Partners.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Do iOS Developer Conference 2026 Amsterdam" theme="2026">
  <main class="page-2026">
    <Hero2026 />

    <section class="newsletter panel">
      <h2 class="section-heading">Stay updated</h2>
      <p class="section-lead">Get announcements on speakers, workshops, and ticket releases.</p>
      <form
        action="https://sendy.appforce1.net/subscribe"
        method="POST"
        accept-charset="utf-8"
        class="newsletter-form"
      >
        <input
          type="email"
          name="email"
          id="email"
          placeholder="Your email address"
          required
        />
        <button type="submit" class="submit-button">Subscribe</button>
        <input type="hidden" name="list" value="AdW3A892ID2J58BxyArjRhFw" />
        <input type="hidden" name="subform" value="yes" />
      </form>
    </section>

    <section class="highlights">
      <p class="intro-copy">
        Do iOS is back in 2026. After 7 successful editions in <a href="/2015">2015</a>, <a href="/2016">2016</a>, <a href="/2018">2018</a>, <a href="/2022">2022</a>, <a href="/2023">2023</a>, <a href="/2024">2024</a>, and <a href="/2025">2025</a> we again invite you to join us in Amsterdam to celebrate iOS development in all its aspects.
      </p>

      <div class="highlights-grid">
        <HighlightCard2026
          accent="cfp"
          title="Call for Papers"
          body="Now open"
          description="Submit your talk or workshop proposal via PaperCall. First-time speaker? We'd love to hear from you. Closes August 16."
          href="https://www.papercall.io/do-ios-2026"
        />
        <HighlightCard2026
          accent="workshops"
          title="Workshops"
          body="November 10"
          description="A day of in-depth workshops. Details and registration will be announced soon."
        />
        <HighlightCard2026
          accent="talks"
          title="Two Days of Inspiring Talks"
          body="November 11–12"
          description="Connect with peers, share knowledge, and celebrate iOS development in the heart of Amsterdam."
        />
      </div>
    </section>

    <section class="panel">
      <Tickets shop="do-ios-2026" />
    </section>

    <section class="panel">
      <Location />
    </section>

    <section class="panel">
      <Hosts />
    </section>

    <section class="panel">
      <Speakers />
    </section>

    <section class="panel">
      <Agenda />
    </section>

    <section class="panel">
      <Support />
    </section>

    <section class="panel panel--accent">
      <CallForPapers />
    </section>

    <section class="panel">
      <Sponsors />
    </section>
  </main>
  <footer class="page-footer">
    <Partners />
    <Footer />
  </footer>
</Layout>

<style>
  .page-2026 {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1rem 2rem;
  }

  .panel {
    background: var(--surface);
    border-radius: var(--radius-lg);
    padding: 2rem;
    margin-bottom: 1.25rem;
    box-shadow: var(--shadow-card);
    border: 1px solid rgba(15, 23, 42, 0.06);
  }

  .panel--accent {
    background: linear-gradient(180deg, #ffffff 0%, #f8f5ff 100%);
    border-color: rgba(107, 0, 151, 0.12);
  }

  .intro-copy {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin: 0 0 1.75rem;
    max-width: 52rem;
  }

  .intro-copy a {
    color: var(--my-blue);
    font-weight: 600;
    text-decoration: none;
  }

  .intro-copy a:hover {
    text-decoration: underline;
  }

  .highlights {
    margin-bottom: 1.25rem;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .newsletter {
    text-align: center;
  }

  .newsletter .section-lead {
    margin-left: auto;
    margin-right: auto;
  }

  .newsletter-form {
    display: flex;
    max-width: 480px;
    margin: 0 auto;
    background: var(--surface-muted);
    padding: 0.35rem;
    border-radius: 999px;
    border: 1px solid rgba(15, 23, 42, 0.08);
  }

  .newsletter-form input[type="email"] {
    flex-grow: 1;
    padding: 0.85rem 1.1rem;
    border: none;
    border-radius: 999px;
    font-size: 1rem;
    background: transparent;
    outline: none;
  }

  .submit-button {
    background: var(--my-blue);
    color: white;
    border: none;
    padding: 0.85rem 1.4rem;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .submit-button:hover {
    background: var(--my-violet);
    transform: translateY(-1px);
  }

  .page-footer {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1rem 2rem;
  }

  @media (max-width: 768px) {
    .panel {
      padding: 1.25rem;
    }

    .newsletter-form {
      flex-direction: column;
      border-radius: var(--radius-lg);
      padding: 0.75rem;
    }

    .newsletter-form input[type="email"],
    .submit-button {
      width: 100%;
      border-radius: 0.75rem;
    }
  }
</style>
