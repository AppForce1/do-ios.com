---
import data from "../data/data-2026.json";
import XButton from "./XButton.astro";
---

<section id="speakers">
  <h2 class="section-heading">Conference Speakers</h2>
  <div class="speaker-grid">
    {
      data.speakers.map((speaker) => {
        const Tag = speaker.placeholder ? "a" : "div";
        const tagProps = speaker.placeholder
          ? {
              href: speaker.cfpUrl,
              target: "_blank",
              rel: "noopener noreferrer",
              class: "speaker-element speaker-placeholder",
              "aria-label": "Submit your talk via the Call for Papers",
            }
          : { class: "speaker-element" };

        return (
          <Tag {...tagProps}>
            <img
              src={speaker.image}
              alt={speaker.placeholder ? "Call for Papers — submit your talk" : `${speaker.name}, Do iOS 2026 speaker`}
            />
            {!speaker.placeholder && <h3>{speaker.name}</h3>}
            {speaker.xHandle && <XButton handle={speaker.xHandle} />}
          </Tag>
        );
      })
    }
  </div>
</section>

<style>
  h2 {
    margin-bottom: 0.25rem;
  }

  .speaker-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    margin: 2rem 0;
  }

  .speaker-element {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .speaker-element h3 {
    font-size: 18px;
    line-height: 24px;
    letter-spacing: -1px;
    font-weight: 800;
    margin: 0;
    background: var(--my-blue);
    color: white;
    padding: 0.5rem 1rem;
    margin-top: -1rem;
    margin-bottom: 1rem;
    border-radius: 0.5rem;
  }

  .speaker-element img {
    border-radius: 50%;
    max-width: 100%;
    aspect-ratio: 1;
    border: 4px solid var(--my-blue);
  }

  .speaker-placeholder {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .speaker-placeholder:hover {
    transform: translateY(-4px);
  }

  .speaker-placeholder img {
    border-style: dashed;
  }

  @media only screen and (max-width: 600px) {
    .speaker-grid {
      padding: 1rem;
    }
  }
</style>
