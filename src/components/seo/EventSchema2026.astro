---
import data from "../../data/data-2026.json";

const site = "https://do-ios.com";

function personId(name: string) {
  return `${site}/#person-${name.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;
}

const confirmedSpeakers = data.speakers.filter((speaker) => !speaker.placeholder);
const performers = [...confirmedSpeakers, ...data.hosts];

const personNodes = performers.map((person) => ({
  "@type": "Person",
  "@id": personId(person.name),
  name: person.name,
  image: `${site}${person.image}`,
  ...(person.xHandle
    ? { sameAs: [`https://x.com/${person.xHandle}`] }
    : {}),
}));

const eventSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${site}/#organization`,
      name: "Do iOS",
      url: `${site}/`,
      logo: `${site}/images/logo-120.png`,
      sameAs: [
        "https://x.com/iosconf",
        "https://hachyderm.io/@appforce1",
      ],
    },
    ...personNodes,
    {
      "@type": "Event",
      "@id": `${site}/#event-2026`,
      name: "Do iOS 2026 — iOS Developer Conference",
      description:
        "Three-day iOS developer conference in Amsterdam with hands-on workshops, inspiring talks, and networking with Europe's iOS community at NEMO Science Museum.",
      startDate: "2026-11-10T09:00:00+01:00",
      endDate: "2026-11-12T18:00:00+01:00",
      eventStatus: "https://schema.org/EventScheduled",
      eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
      inLanguage: "en",
      image: `${site}/images/card.png?v=2026`,
      url: `${site}/`,
      location: {
        "@type": "Place",
        name: "NEMO Science Museum",
        address: {
          "@type": "PostalAddress",
          streetAddress: "Oosterdok 2",
          addressLocality: "Amsterdam",
          postalCode: "1011 VX",
          addressCountry: "NL",
        },
      },
      organizer: {
        "@id": `${site}/#organization`,
      },
      performer: personNodes.map((person) => ({ "@id": person["@id"] })),
      offers: {
        "@type": "Offer",
        url: "https://appforce1.paydro.com/do-ios-2026",
        availability: "https://schema.org/InStock",
        validFrom: "2026-01-01",
      },
      subEvent: [
        {
          "@type": "Event",
          name: "Do iOS 2026 Workshop Day",
          startDate: "2026-11-10T09:00:00+01:00",
          endDate: "2026-11-10T17:00:00+01:00",
          description: "Full-day hands-on iOS development workshops.",
        },
        {
          "@type": "Event",
          name: "Do iOS 2026 Conference Day 1",
          startDate: "2026-11-11T09:00:00+01:00",
          endDate: "2026-11-11T18:00:00+01:00",
          description: "Conference talks, lunch, and walking dinner.",
        },
        {
          "@type": "Event",
          name: "Do iOS 2026 Conference Day 2",
          startDate: "2026-11-12T09:00:00+01:00",
          endDate: "2026-11-12T18:00:00+01:00",
          description: "More conference talks and community networking.",
        },
      ],
    },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />
